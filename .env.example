# ============================================================
# Atlas + Phi-4-mini — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# --- HF Inference Endpoint (fine-tuned Phi-4-mini) -----------
HF_ENDPOINT_URL=https://loatz3ars0j10q2d.eu-west-1.aws.endpoints.huggingface.cloud
HF_TOKEN=hf_your_read_token_here

# Agent settings
LLM_TIMEOUT_SECONDS=120
AGENT_MAX_STEPS=6

# --- Embeddings (runs inside the api container) --------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Postgres ------------------------------------------------
POSTGRES_USER=support
POSTGRES_PASSWORD=support
POSTGRES_DB=support
DATABASE_URL=postgresql+psycopg://support:support@postgres:5432/support

# --- Qdrant --------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=amazon_products_2023
RAG_TOP_K=6

# --- Email (Mailhog for local dev) ---------------------------
# Start with: docker compose --profile dev-mail up -d
# Browser UI: http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@local.test

# --- Optional escalation webhook (Slack/Teams) ---------------
ESCALATION_WEBHOOK_URL=

# --- App -----------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
CORS_ORIGINS=*
